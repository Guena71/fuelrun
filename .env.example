# Strava OAuth — https://www.strava.com/settings/api
# Client ID (public — exposed in frontend via VITE_ prefix)
VITE_STRAVA_CLIENT_ID=your_strava_client_id

# Client Secret (private — server-side only, never expose in frontend)
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret

# Add these in your Vercel dashboard → Project Settings → Environment Variables
